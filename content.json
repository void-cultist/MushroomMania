        "ConfigSchema": {
            "SpawnRate": 
            {
                "AllowValues": "default, lower, higher",
                "Default": "default",
                "AllowBlank": false,
                "Description": "This mod edits the way items spawn. If you find any issues in the amount spawned, change this setting to 'lower'.",
                "Section": "Spawns",
            },
           
            "Include imaginary Mushrooms":
            {
                "AllowValues": "true, false",
                "Default": true,
                "AllowBlank": false,
                "Description": "Toggle this option if you want to play with real mushrooms that exist in real life only.",
                "Section": "Mushroom Configs"
            },
            "All Eyes Planter":
            {
                "AllowValues": "Bush, Crop",
                "Default": "Bush",
                "Description": "Change whether you want the All Eyes planter to be a bush or a normal plantable crop.",
                "Section": "Mushroom Configs"
            },

             "Blue Pinkgill Planter":
            {
                "AllowValues": "Bush, Crop",
                "Default": "Bush",
                "Description": "Change whether you want the Blue Pinkgill planter to be a bush or a normal plantable crop.",
                "Section": "Mushroom Configs"
            },
              "Cornucopia Compatibility":
            {
                "AllowValues": "true, false",
                "Default": false,
                "Description": "If you use all four Cornucopia mod packs, toggle this setting for maximum compatibility. Doesn't do anything if none or not all Cornucopia packs are installed.",
                "Section": "Compatibility"
            },
              "Wildflour Mods Compatibility":
            {
                "AllowValues": "true, false",
                "Default": false,
                "Description": "If you use both 'Rose and the Alchemist' and 'Wildflour Atelier Goods' by Wildflour , toggle this setting for maximum compatibility. Doesn't do anything if none or only one of these mod packs are installed.",
                "Section": "Compatibility"
            },

            "VMV Compatibility":
            {
                "AllowValues": "true, false",
                "Default": false,
                "Description": "If you have Lumisteria's Visit Mount Vapius installed, toggle this setting for maximum compatibility. Doesn't do anything if VMV is not installed.",
                "Section": "Compatibility"
            },
            "Music": 
            {
                "AllowValues": "custom, vanilla",
                "Default": "custom",
                "AllowBlank": false,
                "Description": "This mod adds custom music tracks. If you prefer the original Stardew Valley music, turn this setting off. Custom music might also slow down your game in some instances, so if you are experiencing lag, disable this config as well.",
                "Section": "General"
            },
            "Mushroom Perfection Toggle":
            {
                "AllowValues": "true, false",
                "Default": true,
                "AllowBlank": false,
                "Description": "By default, mushrooms count towards the perfection achievement (shipping collection). Disable this setting if you don't want this.",
                "Section": "General"
            },
            "Potion Perfection Toggle":
            {
                "AllowValues": "true, false",
                "Default": true,
                "AllowBlank": false,
                "Description": "By default, potions count towards the perfection achievement (shipping collection). Disable this setting if you don't want this.",
                "Section": "General"
            }, 
            "Mushroom Spawn Chance":
            {
               "AllowValues": "default, lower, higher",
                "Default": "default",
                "AllowBlank": false,
                "Description": "Change the setting to enable higher or lower mushroom spawn rates.",
                "Section": "Spawns",
            },
            "Mushroom Log Output":
            {
               "AllowValues": "default, custom",
                "Default": "default",
                "AllowBlank": false,
                "Description": "Allows custom mushrooms to be produced by mushroom logs. Mushroom Log Framework required.",
               
            },
    },
     

