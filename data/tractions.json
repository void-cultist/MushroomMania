{
    "Changes": [

        {
            "LogName": "ramen recipe traction",
            "Action": "EditData",
            "Target": "Data/TriggerActions",
            "Entries": {
                "{{ModID}}_RamenUnlock":
                {
                    "Id": "{{ModID}}_RamenUnlock",
                    "Trigger": "DayEnding",
                    "Condition": "Spiderbuttons.BETAS_PLAYER_HAS_COOKED_ITEM Current MM_WildMushroomSoup 1, Spiderbuttons.BETAS_PLAYER_HAS_COOKED_ITEM Current MM_CauliflowerMushroomSoup 1",
                    "Actions": [
                        "Spiderbuttons.BETAS_Message \"{{i18n:RamenUnlock}}\"",
                        "MarkCookingRecipeKnown Current MM_MushroomRamen_Recipe"
                    ]
                }
            }
        },

